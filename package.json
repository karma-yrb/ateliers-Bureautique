{
  "name": "ateliers-bureautique",
  "version": "1.18.0",
  "private": true,
  "description": "Monorepo des ateliers bureautiques Pimms.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "commitmsg:check": "node scripts/validate-commit-message.mjs",
    "do:commit": "if exist \"%LOCALAPPDATA%\\Programs\\Git\\bin\\bash.exe\" (\"%LOCALAPPDATA%\\Programs\\Git\\bin\\bash.exe\" scripts/do-commit.sh) else (bash scripts/do-commit.sh)",
    "do sync": "npm run word:build:data && npm run excel:build:data && npm run powerpoint:build:data && npm run word:sync:app && npm run excel:sync:app && npm run powerpoint:sync:app && npm run word:validate:app-sync && npm run excel:validate:app-sync && npm run powerpoint:validate:app-sync",
    "release": "standard-version",
    "release:first": "standard-version --first-release",
    "release:all": "if exist \"%LOCALAPPDATA%\\Programs\\Git\\bin\\bash.exe\" (\"%LOCALAPPDATA%\\Programs\\Git\\bin\\bash.exe\" scripts/release-all.sh) else (bash scripts/release-all.sh)",
    "lance": "node scripts/run-release-all.mjs",
    "lance pub": "npm run release:all",
    "word:build:data": "npm --prefix apps/word run build:data",
    "word:sync:app": "npm --prefix apps/word run sync:app",
    "word:validate:app-sync": "node packages/atelier-core/scripts/validate-app-sync.mjs --root apps/word",
    "word:repair:encoding": "npm --prefix apps/word run repair:encoding",
    "word:validate:encoding": "npm --prefix apps/word run validate:encoding",
    "word:test": "npm --prefix apps/word test",
    "word:release": "npm --prefix apps/word run release",
    "word:release:all": "npm --prefix apps/word run release:all",
    "excel:build:data": "npm --prefix apps/excel run build:data",
    "excel:sync:app": "npm --prefix apps/excel run sync:app",
    "excel:validate:app-sync": "node packages/atelier-core/scripts/validate-app-sync.mjs --root apps/excel",
    "excel:repair:encoding": "npm --prefix apps/excel run repair:encoding",
    "excel:validate:encoding": "npm --prefix apps/excel run validate:encoding",
    "excel:scrape:data": "npm --prefix apps/excel run scrape:data",
    "excel:revise:data": "npm --prefix apps/excel run revise:data",
    "excel:audit:data": "npm --prefix apps/excel run audit:data",
    "excel:test": "npm --prefix apps/excel test",
    "powerpoint:build:data": "npm --prefix apps/powerpoint run build:data",
    "powerpoint:sync:app": "npm --prefix apps/powerpoint run sync:app",
    "powerpoint:validate:app-sync": "node packages/atelier-core/scripts/validate-app-sync.mjs --root apps/powerpoint",
    "powerpoint:repair:encoding": "npm --prefix apps/powerpoint run repair:encoding",
    "powerpoint:validate:encoding": "npm --prefix apps/powerpoint run validate:encoding",
    "powerpoint:test": "npm --prefix apps/powerpoint test",
    "runtime:validate:word": "node packages/atelier-core/scripts/validate-browser-runtime-sync.mjs --app-root apps/word",
    "runtime:validate:excel": "node packages/atelier-core/scripts/validate-browser-runtime-sync.mjs --app-root apps/excel",
    "runtime:validate:powerpoint": "node packages/atelier-core/scripts/validate-browser-runtime-sync.mjs --app-root apps/powerpoint",
    "runtime:validate": "npm run runtime:validate:word && npm run runtime:validate:excel && npm run runtime:validate:powerpoint",
    "core:test": "npm --prefix packages/atelier-core test",
    "excel:release": "npm --prefix apps/excel run release",
    "excel:release:all": "npm --prefix apps/excel run release:all",
    "powerpoint:release": "npm --prefix apps/powerpoint run release",
    "powerpoint:release:all": "npm --prefix apps/powerpoint run release:all"
  },
  "devDependencies": {
    "standard-version": "^9.5.0"
  }
}
